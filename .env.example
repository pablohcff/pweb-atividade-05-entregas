# Variáveis de ambiente necessárias para executar a aplicação

# Prisma SQLite: caminho relativo ao diretório prisma/ → arquivo fica na raiz do projeto
DATABASE_URL="file:../database.sqlite"

# Porta do servidor HTTP (opcional, padrão: 3002)
PORT=3002

# JWT — obrigatório para autenticação
JWT_SECRET=chave_secreta_minimo_32_caracteres
JWT_EXPIRES_IN=8h
